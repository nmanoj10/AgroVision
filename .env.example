# Frontend - Vite app (port 3000)
VITE_API_URL=http://localhost:5000/api

# Backend - Express server (port 5000)
BACKEND_PORT=5000

# MongoDB Connection
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/agrovision?retryWrites=true&w=majority

# Gemini API Key (get from https://aistudio.google.com)
# GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeather API Key (for weather features)
# OPENWEATHER_API_KEY=your_openweather_key_here

# App Settings
NODE_ENV=development
MODEL_PATH=src/models/trained_model.keras
MODEL_CONFIDENCE_THRESHOLD=85
LOCAL_INFERENCE_TIMEOUT_SECONDS=15
PYTHON_EXECUTABLE=C:\testing\.venv-detect\Scripts\python.exe
